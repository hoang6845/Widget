<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.wallpaper_live.WallpaperLiveFragment">


    <!-- Video nền -->
    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Preview overlay (hiển thị khi xem trước animation) -->
    <com.app.base.ui.animation_preview.AnimationPreviewView
        android:id="@+id/animationPreviewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Container chỉnh sửa ảnh -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/editContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Custom view hiển thị tất cả khung ảnh -->
        <com.app.base.ui.photo_frame_edit.PhotoFrameEditView
            android:id="@+id/photoFrameEditView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1080:1920"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Controls Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <!-- Slot Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/_12dp">

            <Button
                android:id="@+id/btnPrevSlot"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="&lt;"
                android:textSize="16sp"
                android:padding="0dp"
                android:background="@color/white"
                android:textColor="#FFFFFF" />
            <Button
                android:id="@+id/btnBackToEdit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="← Quay lại chỉnh sửa"
                android:visibility="gone"
                tools:visibility="visible"/>

            <TextView
                android:id="@+id/txtSlotLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Khung 1 / 3"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNextSlot"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="&gt;"
                android:textSize="16sp"
                android:padding="0dp"
                android:background="@color/white"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Nút thao tác -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="3">

            <Button
                android:id="@+id/btnImportPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="+ Thêm ảnh"
                android:textSize="13sp"
                android:background="@color/white"
                android:textColor="#000000"
                android:padding="10dp" />

            <Button
                android:id="@+id/btnSaveEdit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="Tiếp theo →"
                android:textSize="13sp"
                android:background="@color/white"
                android:textColor="#FFFFFF"
                android:padding="10dp" />

            <Button
                android:id="@+id/btnPreview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:text="Xem trước"
                android:textSize="13sp"
                android:background="@color/white"
                android:textColor="#FFFFFF"
                android:padding="10dp" />

        </LinearLayout>

        <!-- Nút lưu wallpaper (chỉ hiện ở preview mode) -->
        <Button
            android:id="@+id/btnSaveWallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="💾 Lưu làm Wallpaper"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@color/white"
            android:textColor="#000000"
            android:padding="14dp"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>