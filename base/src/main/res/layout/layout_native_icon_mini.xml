<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/native_ad_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/dp_8"
    android:layout_marginBottom="@dimen/dp_6"
    android:background="@drawable/bg_ads_small_transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/llPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toStartOf="@id/ad_notification_view"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_10dp"
                android:layout_marginStart="@dimen/dp_6"
                app:cardCornerRadius="4dp">

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@id/icon"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    tools:src="@tools:sample/avatars" />

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/poppins_medium"
                        android:includeFontPadding="false"
                        android:lines="1"
                        android:paddingHorizontal="@dimen/_4dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/_14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/cardView"
                        app:layout_constraintTop_toTopOf="@+id/cardView"
                        tools:text="@tools:sample/lorem/random" />

                    <LinearLayout
                        android:id="@+id/llBody"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/body"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:fontFamily="@font/poppins_medium"
                            android:gravity="start"
                            android:maxLines="2"
                            android:paddingHorizontal="@dimen/_4dp"
                            android:textColor="@color/gray_3d3d3d"
                            android:textSize="@dimen/_12sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@id/primary"
                            app:layout_constraintTop_toBottomOf="@id/primary"
                            tools:text="@tools:sample/lorem/random" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/ll_cta"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/common_dimen_44dp"
            android:layout_marginEnd="@dimen/dp_6"
            android:background="@drawable/bg_button_ads"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.brally.mobile.ui.components.widgets.StrokedTextView
                android:id="@+id/cta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginHorizontal="@dimen/_8dp"
                android:fontFamily="@font/font_semi_bold"
                android:gravity="center"
                android:text="@string/title_install"
                android:textColor="@color/colorTitleButtonAds"
                android:textSize="@dimen/_16sp" />
        </FrameLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/ad_notification_view"
            android:layout_width="@dimen/native_ad_choise_width"
            android:layout_height="@dimen/native_ad_choice_height"
            android:layout_gravity="top|start"
            android:layout_marginEnd="@dimen/_2dp"
            android:background="@drawable/bg_ads_choice"
            android:backgroundTint="@color/light_gray"
            android:gravity="center"
            android:text="@string/title_ad_choce"
            android:textColor="@color/gray_3d3d3d"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/ll_cta"
            app:layout_constraintEnd_toStartOf="@id/ll_cta"
            app:layout_constraintTop_toTopOf="@id/ll_cta" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.gms.ads.nativead.NativeAdView>