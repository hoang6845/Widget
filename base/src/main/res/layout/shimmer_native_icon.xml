<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmerContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/_10dp"
    android:background="@color/gray_c9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_8dp"
        android:background="@color/gray_c9">

        <View
            android:id="@+id/cardView"
            android:layout_width="@dimen/_48dp"
            android:layout_height="@dimen/_48dp"
            android:background="@drawable/common_bg_shimmer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/shimmer_title"
            android:layout_width="0dp"
            android:layout_height="@dimen/_16dp"
            android:layout_marginStart="@dimen/_8dp"
            android:background="@drawable/common_bg_shimmer"
            app:layout_constraintStart_toEndOf="@id/cardView"
            app:layout_constraintTop_toTopOf="@id/cardView"
            app:layout_constraintEnd_toStartOf="@+id/shimmer_badge" />

        <View
            android:id="@+id/shimmer_badge"
            android:layout_width="0dp"
            android:layout_height="@dimen/_28dp"
            android:background="@drawable/common_bg_shimmer"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="@dimen/_8dp"
            app:layout_constraintStart_toEndOf="@+id/cardView"
            app:layout_constraintTop_toTopOf="@id/cardView" />

        <View
            android:id="@+id/shimmer_body"
            android:layout_width="0dp"
            android:layout_height="@dimen/_20dp"
            android:background="@drawable/common_bg_shimmer"
            app:layout_constraintEnd_toEndOf="@+id/shimmer_badge"
            app:layout_constraintHorizontal_bias="0.071"
            app:layout_constraintStart_toStartOf="@id/shimmer_badge"
            app:layout_constraintTop_toBottomOf="@id/shimmer_badge" />

        <View
            android:id="@+id/shimmer_divider"
            android:layout_width="0dp"
            android:layout_height="@dimen/_1dp"
            android:layout_marginTop="@dimen/_4dp"
            android:background="@color/common_black_a10"
            app:layout_constraintTop_toBottomOf="@id/shimmer_body"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/shimmer_cta"
            android:layout_width="0dp"
            android:layout_height="@dimen/_48dp"
            android:layout_marginTop="@dimen/_8dp"
            android:layout_marginBottom="@dimen/_4dp"
            android:background="@drawable/common_bg_shimmer"
            app:layout_constraintTop_toBottomOf="@id/shimmer_divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.facebook.shimmer.ShimmerFrameLayout>